# ===========================================
# Loop SDK (wallet — signing happens here)
# ===========================================
PRIVATE_KEY=
PARTY_ID=
# testnet | mainnet | local
LOOP_NETWORK=
WALLET_URL=
API_URL=

# ===========================================
# Temple (Lightspeed) — API key only
# ===========================================
# testnet | mainnet
NETWORK=
TEMPLE_API_KEY=

# Temple WebSocket (market maker: orderbook + trades — see docs/TEMPLE_MM_ARCHITECTURE.md)
TEMPLE_WS_URL=

# ===========================================
# Binance — reference price (fair value / ticker route)
# ===========================================
# wss://stream.binance.com:9443/ws/btcusdt@bookTicker
BINANCE_WS_URL=

# ===========================================
# HTTP server
# ===========================================
SERVER_API_KEY=
PORT=

# ===========================================
# Optional: fetch / exchange scripts only (unchanged if unused)
# ===========================================
# TEMPLE_FETCH_NETWORK=
# TEMPLE_ACCESS_TOKEN=
# EXCHANGE_TICKER_ID=
# EXCHANGE_HISTORICAL_LIMIT=
# EXCHANGE_LOOKBACK_DAYS=

# ===========================================
# In-repo market maker (npm run mm)
# Primary triggers: Binance WS move + Temple WS trades. Not the timer below.
# ===========================================
# MM_DRY_RUN=true
# MM_SYMBOL=CBTC/USDCx
# Safety / REST reconciliation only (see TEMPLE_MM_ARCHITECTURE.md §6). Legacy alias: MM_POLL_MS
# MM_SAFETY_RECONCILE_MS=5000
# Phase 1 ~40 bps total spread → 20 bps per side (half-spread)
# MM_HALF_SPREAD_BPS=20
# Extra bps from mid for level-2 vs level-1 on each side (strategy.ts: L2 uses bidBps+gap, not “whole ladder width”).
# Arch example ~30 bps between adjacent rungs → default 30 (was 3 = unrealistically tight between L1/L2).
# MM_LEVEL_GAP_BPS=30
# Inventory: tiltBps = invRatio * MM_INV_SKEW_MAX_BPS * MM_INVENTORY_SKEW_FACTOR (single formula — factor scales, max bps caps at full inv when factor=1).
# MM_INV_SKEW_MAX_BPS=8
# MM_INVENTORY_SKEW_FACTOR=0.7
# MM_ORDER_SIZE=0.003
# MM_MAX_POSITION_BASE=0.05
# Desired vs live order price tolerance (anti-churn); not in arch doc but standard MM hygiene
# MM_PRICE_MATCH_BPS=2
# REST orderbook depth if needed; fair price is Binance WS
# MM_ORDERBOOK_LEVELS=5
# MM_ACTIVE_ORDER_LIMIT=50
# MM_REQUOTE_THRESHOLD_BPS=8
# MM_BASIS_WARN_BPS=50
# MM_BASIS_HALT_BPS=100
# MM_BASIS_WIDEN_MAX_SCALE=2
# MM_BASIS_HALT_CANCEL_ALL=false
